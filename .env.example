# NetMon server configuration — copy to .env and fill in.
# Everything here is read at server startup (via run.sh which sources .env).

# ---- API auth (mandatory) ----
# Server auto-generates this on first launch if unset and logs the value.
# The iPhone app expects it in Settings > API token.
NETMON_API_TOKEN=

# ---- Device passwords ----
# Device `kind` + `username` are in config.yaml; passwords are env-only
# so they never land in the repo. Env var names follow the pattern
# NETMON_<device_id_uppercase>_PASSWORD (matches the `id:` field of
# each device entry in config.yaml).
NETMON_UDM_PASSWORD=
NETMON_BR1_PASSWORD=
NETMON_BALANCE310_PASSWORD=

# ---- APNs (optional — enables iPhone lock-screen notifications) ----
# Leave blank to disable push. Generate a .p8 key at
# developer.apple.com > Certificates, Identifiers & Profiles > Keys,
# drop it in ./secrets/, and set APNS_KEY_PATH to its absolute path.
APNS_KEY_PATH=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.gbellas.netmon
# "sandbox" for Xcode dev builds, "production" for TestFlight / App Store.
APNS_ENV=sandbox
